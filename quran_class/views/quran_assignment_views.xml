<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_class_assignment_list" model="ir.ui.view">
        <field name="name">class.assignment.list</field>
        <field name="model">class.assignment</field>
        <field name="arch" type="xml">
            <list string="Assignments">
                <field name="student_id"/>
                <field name="assignment_type"/>
                <field name="surah"/>
                <field name="due_date"/>
                <field name="given_session_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'assigned'"
                       decoration-success="state == 'submitted'"
                       decoration-warning="state == 'partial'"
                       decoration-danger="state == 'missed'"/>
            </list>
        </field>
    </record>

    <record id="view_class_assignment_form" model="ir.ui.view">
        <field name="name">class.assignment.form</field>
        <field name="model">class.assignment</field>
        <field name="arch" type="xml">
            <form string="Assignment">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Assignment">
                            <field name="student_id"/>
                            <field name="given_session_id"/>
                            <field name="assignment_type"/>
                            <field name="due_date"/>
                        </group>
                        <group string="Range">
                            <field name="surah"/>
                            <field name="ayah_from"/>
                            <field name="ayah_to"/>
                        </group>
                    </group>
                    <group string="Submission">
                        <group>
                            <field name="submission_date"/>
                            <field name="submission_rating"/>
                        </group>
                    </group>
                    <field name="submission_notes" placeholder="Submission notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_class_assignment" model="ir.actions.act_window">
        <field name="name">Assignments</field>
        <field name="res_model">class.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
